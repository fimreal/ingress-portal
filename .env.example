# Ingress Portal 环境变量示例
# 复制此文件为 .env 并修改相应配置

# 服务端口
PORT=8080

# Super Mode 认证类型: token 或 password
SUPER_MODE=token

# Super Mode 密码 (当 SUPER_MODE=password 时使用)
# SUPER_PASSWORD=your-secret-password

# Token 有效期 (小时)
TOKEN_TTL=24

# Kubeconfig 路径 (可选，默认使用 ~/.kube/config)
# KUBECONFIG=/path/to/kubeconfig

# Gin 运行模式: debug 或 release
# GIN_MODE=debug
